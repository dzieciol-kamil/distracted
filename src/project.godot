; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Distracted"
config/description="Endless walker — pedestrian on their phone vs traffic"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.4", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"
SceneManager="*res://scripts/autoloads/scene_manager.gd"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
NotificationManager="*res://scripts/autoloads/notification_manager.gd"
HazardSpawner="*res://scripts/autoloads/hazard_spawner.gd"

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

